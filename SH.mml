<m-character id="shark-avatar" src="https://drive.google.com/uc?export=download&id=1R-gfns-VwA1SYZzjUHdPBPpzsuwM8FOU"></m-character>

<script>
  // Dynamically grab the token ID passed by the metaverse viewer/marketplace URL
  const urlParams = new URLSearchParams(window.location.search);
  const tokenId = urlParams.get('tokenId') || urlParams.get('id') || '1';
  
  // Apply the token ID directly to the character element attributes
  const characterElement = document.getElementById('shark-avatar');
  if (characterElement) {
    characterElement.setAttribute('token-id', tokenId);
    console.log(`Successfully initialized MML asset with Token ID: ${tokenId}`);
  }
</script>
